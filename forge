#!/usr/bin/env php
<?php

// Verifica se a pasta vendor existe (se o composer install foi rodado)
if (!file_exists(__DIR__ . '/vendor/autoload.php')) {
    echo "Erro: Rode 'composer install' primeiro para gerar o autoload.\n";
    exit(1);
}

require __DIR__ . '/vendor/autoload.php';

// Carrega as variáveis de ambiente do .env (necessário para que getenv() funcione no CLI)
if (class_exists(\Dotenv\Dotenv::class) && file_exists(__DIR__ . '/.env')) {
    $dotenv = \Dotenv\Dotenv::createUnsafeImmutable(__DIR__);
    $dotenv->safeLoad();
}

// Registra o tratador global de exceções
$exceptionHandler = new \Core\Exceptions\Handler();
$exceptionHandler->register();

use Core\Console\Kernel;

$console = new Kernel();
$console->handle($argv);
